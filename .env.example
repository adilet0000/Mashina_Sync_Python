# Copy to .env for local development.
# Do not put real credentials in this example file.

APP_ENV=local

# New catalog database URL, for example:
# postgresql+psycopg://user:password@host:5432/database
CATALOG_DATABASE_URL=

# Sync safety defaults.
SYNC_TARGET=catalog
SYNC_DRY_RUN=1
SYNC_ALLOW_CATALOG_WRITES=0
SYNC_CATALOG_USER_ID=
SYNC_CATALOG_DEFAULT_STATUS=active
SYNC_CATALOG_INACTIVE_STATUS=inactive
SYNC_CATALOG_IMAGE_STATUS=1
SYNC_CATALOG_IMAGE_INACTIVE_STATUS=0
SYNC_BATCH_SIZE=100
SYNC_HTTP_TIMEOUT=30
SYNC_LOG_LEVEL=INFO

# Provider feed overrides. Leave empty to use built-in legacy URLs.
SYNC_PROVIDER_AUTOHUB_FEED_URL=
SYNC_PROVIDER_AUTOLAND_FEED_URL=
SYNC_PROVIDER_SHREDDER_FEED_URL=
SYNC_PROVIDER_OKAYAMAOMSK_FEED_URL=
SYNC_PROVIDER_BANZAIMOTORS_PARTS_FEED_URL=
SYNC_PROVIDER_BANZAIMOTORS_WHEELS_FEED_URL=
SYNC_PROVIDER_BAVARIA_PARTS_FEED_URL=
SYNC_PROVIDER_BAVARIA_WHEELS_FEED_URL=
SYNC_PROVIDER_SHINABAR_FEED_URL=
SYNC_PROVIDER_AVTOINSTALL_FEED_URL=
SYNC_PROVIDER_ALLMOTORS_BASE_URL=
SYNC_PROVIDER_AUTOSHINA_BASE_URL=
SYNC_PROVIDER_DETALKG_PARTS_FEED_URL=
SYNC_PROVIDER_DETALKG_BASE_URL=
SYNC_PROVIDER_TOYOTA_FEED_URL=
SYNC_PROVIDER_TOYOTA_TRADEIN_FEED_URL=
SYNC_PROVIDER_TOYOTA_TRADEIN_CURRENCY_RATE=
SYNC_PROVIDER_LEXUS_FEED_URL=
SYNC_PROVIDER_KIA_FEED_URL=

# Optional default phones applied if provider-specific phones are empty.
SYNC_CATALOG_PHONES=

# Provider-specific catalog user ids.
SYNC_CATALOG_USER_ID_AUTOHUB=
SYNC_CATALOG_USER_ID_AUTOLAND=
SYNC_CATALOG_USER_ID_SHREDDER=
SYNC_CATALOG_USER_ID_OKAYAMAOMSK=
SYNC_CATALOG_USER_ID_BANZAIMOTORS=
SYNC_CATALOG_USER_ID_BAVARIA=
SYNC_CATALOG_USER_ID_SHINABAR=
SYNC_CATALOG_USER_ID_AVTOINSTALL=
SYNC_CATALOG_USER_ID_ALLMOTORS=
SYNC_CATALOG_USER_ID_AUTOSHINA=
SYNC_CATALOG_USER_ID_DETALKG=
SYNC_CATALOG_USER_ID_TOYOTA=
SYNC_CATALOG_USER_ID_TOYOTA_TRADEIN=
SYNC_CATALOG_USER_ID_LEXUS=
SYNC_CATALOG_USER_ID_KIA=

# Provider-specific phones, comma-separated.
SYNC_CATALOG_PHONES_AUTOHUB=
SYNC_CATALOG_PHONES_AUTOLAND=
SYNC_CATALOG_PHONES_SHREDDER=
SYNC_CATALOG_PHONES_OKAYAMAOMSK=
SYNC_CATALOG_PHONES_BANZAIMOTORS=
SYNC_CATALOG_PHONES_BAVARIA=
SYNC_CATALOG_PHONES_SHINABAR=
SYNC_CATALOG_PHONES_AVTOINSTALL=
SYNC_CATALOG_PHONES_ALLMOTORS=
SYNC_CATALOG_PHONES_AUTOSHINA=
SYNC_CATALOG_PHONES_DETALKG=
SYNC_CATALOG_PHONES_TOYOTA=
SYNC_CATALOG_PHONES_TOYOTA_TRADEIN=
SYNC_CATALOG_PHONES_LEXUS=
SYNC_CATALOG_PHONES_KIA=
